{
  "name": "status",
  "layer": "bottom",
  "position": "bottom",
  "width": "100%",
  "height": 50,
  "gaps": 10,
  "spacing": 4,
  "modules-left": ["custom/audio", "custom/steam"],
  "modules-center": ["custom/window"],
  "modules-right": ["custom/pulseaudio", "custom/backlight", "custom/battery", "custom/clock"],
  "fixed-center": true,

  "custom/audio": {
    "exec": "~/.config/waybar/scripts/playerctl.sh",
    "interval": 1,
    "return-type": "json",  
    "signal": 1,
    "on-click": "~/.config/waybar/scripts/playpause.sh && pkill -RTMIN+1 waybar",
    "on-scroll-up": "echo $((($(cat /tmp/current_player_index) + 1))) > /tmp/current_player_index && pkill -RTMIN+1 waybar",
    "on-scroll-down": "echo $((($(cat /tmp/current_player_index) - 1))) > /tmp/current_player_index && pkill -RTMIN+1 waybar"
  },

  "custom/steam": {
    "exec": "~/.config/waybar/scripts/find_game.sh",
    "interval": 1,
    "return-type": "plain",
    "tooltip": false
  },

  "custom/window": {
    "exec": "~/.config/waybar/scripts/window_title.sh",
    "interval": 1,
    "tooltip": false
  },

  "custom/pulseaudio": {
    "exec": "~/.config/waybar/scripts/volume.sh",
    "interval": 1,
    "tooltip": false,
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle; hyprctl dispatch redraw",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ -1%; hyprctl dispatch redraw",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ +1%; hyprctl dispatch redraw"
  },

  "custom/backlight": {
    "exec": "echo \" 󱥤$(brightnessctl | grep -oE '[0-9]+%' | sed 's/%//' | xargs python3 ~/.config/waybar/scripts/nnp.py) \"",
    "interval": 1,
    "tooltip": false,
    "on-scroll-up": "brightnessctl set 2%-",
    "on-scroll-down": "brightnessctl set +2%"
  },

  "custom/battery": {
    "exec": "~/.config/waybar/scripts/battery.sh",
    "return-type": "json",  
    "interval": 1,
    "tooltip": false,
    "states": {
      "warning": 20,
      "critical": 10
    }
  },

  "custom/clock": {
    "exec": "echo \" 󱥫$(date +'%Y󱦜%m󱦜%d󱦜%H󱦝%M󱦝%S' | xargs -I {} python3 ~/.config/waybar/scripts/nnp.py {} 4.1.2.2.2.2 ) \"",
    "interval": 1,
    "tooltip": false
  }
}
